node_modules/
.pi/auth.json
.env*
dist/
build/
.DS_Store
node_modules
nul

# Agent session data and test traces (keep directory structure)
.pi/agent/sessions/*
!.pi/agent/sessions/.gitkeep

# Wiki database and concepts network (keep directory structure)
wiki_core/concepts/*
!wiki_core/concepts/.gitkeep
wiki_core/temporary/*
!wiki_core/temporary/.gitkeep
wiki_core/archive/*
!wiki_core/archive/.gitkeep

# QQ Bot Logger output & checkin logs in knowledge bases
inbox/qq-logs/
knowledge_bases/*/inbox/qq-logs/
**/inbox/checkin_logs.jsonl

# NapCat: large binaries (deployed by setup-napcat.ps1)
napcat/node.exe
napcat/napcat.mjs
napcat/wrapper.node
napcat/major.node
napcat/QQNT.dll
napcat/*.dll
napcat/node_modules/
napcat/native/
napcat/static/
napcat/worker/
napcat/plugins/

# NapCat: runtime-generated files
napcat/cache/
napcat/logs/
napcat/*.db*
napcat/*.log
napcat/config/napcat_*.json
napcat/config/onebot11_*.json
napcat/config/napcat_protocol_*.json

# NapCat: deployment leftovers
napcat.zip

# Custom (non-preset) skills under skills/ and .pi/skills/
skills/*/
.pi/skills/*/
