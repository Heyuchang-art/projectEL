node_modules/
.pi/auth.json
.env*
dist/
build/
.DS_Store
node_modules
nul

# Agent session data and test traces (keep directory structure)
.pi/agent/sessions/*
!.pi/agent/sessions/.gitkeep

# Wiki database and concepts network (keep directory structure)
wiki_core/concepts/*
!wiki_core/concepts/.gitkeep
wiki_core/temporary/*
!wiki_core/temporary/.gitkeep
wiki_core/archive/*
!wiki_core/archive/.gitkeep

# QQ Bot Logger output & checkin logs in knowledge bases
inbox/qq-logs/
knowledge_bases/*/inbox/qq-logs/
**/inbox/checkin_logs.jsonl

# NapCat: entire directory auto-deployed by scripts/setup-napcat.ps1
# QQ NT runtime creates temp dirs in its working directory (TCD*.tmp,
# chrome_drag*, scoped_dir*, etc.) — normal behavior, not tracked.
napcat/

# Custom (non-preset) skills under skills/ and .pi/skills/
skills/*/
.pi/skills/*/
